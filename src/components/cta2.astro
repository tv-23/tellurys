<style>
    :root {
        --orange: #bf4a1a;
        --black: #121212;
        --white: #efedea;
        --ease: cubic-bezier(0.16, 1, 0.3, 1);
    }

    .cta-container {
        position: relative;
        width: 100%;
        min-height: 120vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 100px 5%;
    }

    /* --- LA LENTILLE GÉOPHYSIQUE (Arrière-plan) --- */
    .lens-bg {
        position: absolute;
        width: 700px;
        height: 700px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 50%;
        pointer-events: none;
        transition: all 0.6s var(--ease);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .lens-inner {
        width: 60%;
        height: 60%;
        border: 1px solid var(--orange);
        border-radius: 50%;
        background: radial-gradient(
            circle,
            rgba(179, 58, 27, 0.05) 0%,
            transparent 70%
        );
        box-shadow: 0 0 80px rgba(179, 58, 27, 0.1);
        position: relative;
    }

    /* --- MISE EN PAGE DU CONTENU --- */
    .cta-content {
        position: relative;
        z-index: 10;
        width: 100%;
        max-width: 1300px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: flex-start;
    }

    .cta-header h2 {
        font-size: clamp(2rem, 5vw, 4.5rem);
        line-height: 0.9;
        text-transform: uppercase;
        margin-bottom: 30px;
    }

    .cta-header p {
        font-size: 1.1rem;
        color: #777;
        max-width: 450px;
        line-height: 1.6;
        margin-bottom: 40px;
    }

    /* --- LE FORMULAIRE ARRONDIE --- */
    .modern-form {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

