    /* --- BOUTON SUBMIT CIRCULAIRE --- */
    .submit-container {
        display: flex;
        justify-content: flex-end;
        margin-top: 20px;
    }

    .btn-submit {
        width: 140px;
        height: 140px;
        background: var(--orange);
        border-radius: 50%;
        border: none;
        color: white;
        font-size: 10px;
        cursor: pointer;
        transition: 0.5s var(--ease);
        box-shadow: 0 15px 40px rgba(179, 58, 27, 0.3);
        display: flex;
        align-items: center;
