<script>
    // 1. EFFET PARALLAXE SUR LA LENTILLE
    const lens = document.getElementById("lens");
    const lensInner = document.getElementById("lens-inner");
    const section = document.getElementById("cta-section");

    section.addEventListener("mousemove", (e) => {
        const x = (e.clientX - window.innerWidth / 2) / 20;
        const y = (e.clientY - window.innerHeight / 2) / 20;
        lens.style.transform = `translate(${x}px, ${y}px)`;
    });

    // 2. RÉACTION DE LA LENTILLE AU FOCUS
    const inputs = document.querySelectorAll("input, select, textarea");
    inputs.forEach((input) => {
        input.addEventListener("focus", () => {
            lensInner.style.boxShadow = "0 0 150px rgba(179, 58, 27, 0.4)";
            lensInner.style.borderColor = "#ffffff";
        });
        input.addEventListener("blur", () => {
            lensInner.style.boxShadow = "0 0 80px rgba(179, 58, 27, 0.1)";
            lensInner.style.borderColor = "#b33a1b";
        });
    });

    // 3. ANIMATION D'ENTRÉE
    const observer = new IntersectionObserver(
        (entries) => {
            if (entries[0].isIntersecting) {
                section.classList.add("is-visible");
            }
        },
        { threshold: 0.2 },
    );

    observer.observe(section);
</script>
