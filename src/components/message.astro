---
const lang = Astro.url.pathname.startsWith("/en") ? "en" : "fr";

const t = {
  fr: {
    tagline: "Tellurys | Conseil Stratégique",
    welcome: "Bonjour et bienvenue chez <strong>Tellurys</strong> 👋<br><br>Souhaitez-vous découvrir nos expertises ou obtenir une proposition personnalisée ?",
    btn_services: "🔎 Découvrir nos services",
    btn_quote: "📄 Obtenir un devis",
    btn_calendar: "📅 Prendre un RDV",
    btn_callback: "💬 Être rappelé",
    placeholder: "Écrivez ici...",
  },
  en: {
    tagline: "Tellurys | Strategic Consulting",
    welcome: "Hello and welcome to <strong>Tellurys</strong> 👋<br><br>Would you like to discover our expertise or get a personalized proposal?",
    btn_services: "🔎 Our Services",
    btn_quote: "📄 Get a Quote",
    btn_calendar: "📅 Book a Meeting",
    btn_callback: "💬 Callback Request",
    placeholder: "Type here...",
  }
}[lang];
---

<div class="chat-container hidden" id="chatContainer">
  <!-- HEADER -->
  <div class="chat-header">
    <div style="display: flex; align-items: center; gap: 10px;">
      <div class="online-status-dot"></div>
      <div style="text-align: left;">
        <strong style="display: block; font-size: 14px;">Tellurys Connect</strong>
        <small style="font-size: 9px; opacity: 0.8;">{t.tagline}</small>
      </div>
    </div>
    <button class="close-btn" id="closeChatBtn">✕</button>
  </div>

  <!-- CHAT BODY -->
  <div class="chat-body" id="chatBody">
    <div class="message-row receiver">
      <div class="message-bubble" set:html={t.welcome} />
    </div>

    <div class="quick-replies" id="initialActions">
      <div class="quick-reply" onclick="window.startFlow('SERVICES')">{t.btn_services}</div>
      <div class="quick-reply" onclick="window.startFlow('QUOTE')">{t.btn_quote}</div>
      <div class="quick-reply" onclick="window.startFlow('CALENDAR')">{t.btn_calendar}</div>
      <div class="quick-reply" onclick="window.startFlow('CALLBACK')">{t.btn_callback}</div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const lang = window.location.pathname.startsWith("/en") ? "en" : "fr";

    

    const t = {
      fr: {
        serv_intro: "Nous accompagnons les entreprises autour de trois expertises stratégiques :<br><br>🧭 1. <strong>Exploration</strong> (Audit)<br>📊 2. <strong>Analyse</strong> (Performance)<br>🚀 3. <strong>Conseil</strong> (Transformation)",
        q_step1: "Pour préparer une proposition adaptée, quel est votre besoin principal ?",
        q_step2: "Dans quel secteur évolue votre entreprise ?",
        q_step3: "Quel est votre délai souhaité ?",
        q_step4: "Merci pour ces informations 🙏<br>Où pouvons-nous vous envoyer votre proposition personnalisée ?",
        btn_calendly: "📅 Choisir un créneau",
        btn_callback: "📞 Être rappelé",
        btn_cases: "Voir les cas clients",
        btn_articles: "Lire nos articles",
        callback_msg: "Merci pour votre intérêt envers Tellurys. Notre équipe vous contactera sous <strong>24h maximum</strong>.<br><br>En attendant, souhaitez-vous consulter nos réalisations ?",
        err: "Veuillez remplir tous les champs."
      },
      en: {
        serv_intro: "We support companies through three strategic expertises:<br><br>🧭 1. Exploration<br>📊 2. Analysis<br>🚀 3. Strategy",
        q_step1: "What is your main project need?",
        q_step2: "What is your industry sector?",
        q_step3: "What is your desired timeline?",
        q_step4: "Thank you for this info 🙏<br>Where should we send your personalized proposal?",
        btn_calendly: "📅 Choose a slot",
        btn_callback: "📞 Call me back",
        btn_cases: "View Case Studies",
        btn_articles: "Read our articles",
        callback_msg: "Thank you for your interest. Our team will contact you within <strong>24h maximum</strong>.<br><br>In the meantime, would you like to see our work?",
        err: "Please fill all fields."
      }
    }[lang];

    window.leadData = {};

    window.addBotMsg = (html) => {
      const b = document.getElementById("chatBody");
      const r = document.createElement("div");
      r.className = "message-row receiver";
      r.innerHTML = `<div class="message-bubble">${html}</div>`;
      b.appendChild(r);
      b.scrollTop = b.scrollHeight;
    };

    window.addUserMsg = (text) => {
      const b = document.getElementById("chatBody");
      const r = document.createElement("div");
      r.className = "message-row sender";
      r.innerHTML = `<div class="message-bubble">${text}</div>`;
      b.appendChild(r);
      b.scrollTop = b.scrollHeight;
    };

    window.renderButtons = (labels, callback) => {
      const b = document.getElementById("chatBody");
      const c = document.createElement("div");
      c.className = "quick-replies";
      labels.forEach(l => {
        const btn = document.createElement("div");
        btn.className = "quick-reply";
        btn.textContent = l;
        btn.onclick = () => { c.remove(); window.addUserMsg(l); callback(l); };
        c.appendChild(btn);
      });
      b.appendChild(c);
      b.scrollTop = b.scrollHeight;
    };

    window.startFlow = (flow) => {
      document.getElementById("initialActions")?.remove();

      if (flow === 'SERVICES') {
        window.addBotMsg(t.serv_intro);
        window.renderButtons(["Exploration", "Analyse", "Conseil stratégique"], (choice) => {
            window.leadData.interest = choice;
            window.addBotMsg("Souhaitez-vous :");
            window.renderButtons(["📘 Brochure", "📞 Parler à un conseiller", "📅 Appel stratégique"], (action) => {
                if(action.includes("📅") || action.includes("📞")) window.startFlow('CALENDAR');
                else window.startFlow('CLOSING');
            });
        });
      } 

      else if (flow === 'QUOTE') {
        window.addBotMsg(t.q_step1);
        window.renderButtons(["Lancer un projet", "Optimiser existant", "Audit stratégique", "Autre"], (p) => {
            window.leadData.type = p;
            window.addBotMsg(t.q_step2);
            window.renderButtons(["Industrie", "Technologie", "Services", "Immobilier", "Autre"], (s) => {
                window.leadData.sector = s;
                window.addBotMsg(t.q_step3);
                window.renderButtons(["Urgent", "1-3 mois", "3-6 mois", "Réflexion"], (d) => {
                    window.leadData.delay = d;
                    window.renderLeadForm();
                });
            });
        });
      }

      else if (flow === 'CALENDAR') {
          window.addBotMsg("Comment souhaitez-vous procéder ?");
          window.renderButtons([t.btn_calendly, t.btn_callback], (choice) => {
              if(choice.includes("📅")) {
                  window.addUserMsg(t.btn_calendly);
                  window.addBotMsg("👉 <a href='https://calendly.com' target='_blank' style='color:var(--tellurys-accent); font-weight:bold;'>Cliquez ici pour choisir votre créneau</a>");
              } else {
                  window.startFlow('CALLBACK');
              }
          });
      }

      else if (flow === 'CALLBACK' || flow === 'CLOSING') {
          window.addBotMsg(t.callback_msg);
          const links = document.createElement("div");
          links.className = "quick-replies";
          links.innerHTML = `
            <a href="/cas-clients" class="quick-reply" style="text-decoration:none">${t.btn_cases}</a>
            <a href="/blog" class="quick-reply" style="text-decoration:none">${t.btn_articles}</a>
            <div class="quick-reply" onclick="window.location.reload()">🏠 Accueil</div>
          `;
          document.getElementById("chatBody").appendChild(links);
          console.log("LEAD COLLECTED:", window.leadData);
      }
    };

    window.renderLeadForm = () => {
        window.addBotMsg(t.q_step4);
        const b = document.getElementById("chatBody");
        const f = document.createElement("div");
        f.className = "chat-form";
        f.innerHTML = `
            <input type="text" id="f_name" placeholder="Nom complet" required>
            <input type="email" id="f_email" placeholder="Email professionnel" required>
            <input type="tel" id="f_tel" placeholder="Téléphone">
            <input type="text" id="f_company" placeholder="Entreprise">
            <button class="submit-btn" onclick="window.submitLeadForm()">Envoyer ma demande</button>
        `;
        b.appendChild(f);
        b.scrollTop = b.scrollHeight;
    };

    window.submitLeadForm = () => {
        const n = (document.getElementById("f_name") as HTMLInputElement).value;
        const e = (document.getElementById("f_email") as HTMLInputElement).value;
        const t_ = (document.getElementById("f_tel") as HTMLInputElement).value;
        const c = (document.getElementById("f_company") as HTMLInputElement).value;

        if(!n || !e) return alert(t.err);
        
        window.leadData = {...window.leadData, name: n, email: e, phone: t_, company: c};
        document.querySelector(".chat-form").remove();
        window.addUserMsg("Formulaire envoyé");
        window.startFlow('CLOSING');
    };

    
    document.getElementById("chat-button").onclick = () => {
      document.getElementById("chatContainer").classList.toggle("hidden");
    };

    // Auto-open logic
    // const chatContainer = document.getElementById("chatContainer");
    // setTimeout(() => chatContainer.classList.remove("hidden"), 5000);
    document.getElementById("closeChatBtn").onclick = () => chatContainer.classList.add("hidden");



    function syncChatIconPosition() {
  const scrollBtn = document.querySelector('.tt-scroll-to-top');
  const chatIcon = document.querySelector('.chat-icon');

  if (scrollBtn && chatIcon) {
    const styles = window.getComputedStyle(scrollBtn);

    const rightValue = styles.right;
    const widthValue = styles.width;
    const heightValue = styles.height;

    chatIcon.style.right = rightValue;
    chatIcon.style.height = heightValue;
    chatIcon.style.width = widthValue;
  }
}

window.addEventListener('load', syncChatIconPosition);
window.addEventListener('resize', syncChatIconPosition);
  });
</script>