---
import Layout from "../layouts/Layout.astro";
import CTA from '../components/cta.astro';
---

<Layout>
    <div id="tt-content-wrap">

        <!-- ================= HERO ================= -->
        <div
            id="page-header"
            class="ph-full ph-full-m ph-cap-xxxxlg ph-center ph-image-parallax ph-caption-parallax"
        >

            <!-- BASE -->
            <div class="page-header-inner tt-wrap">
                <div class="ph-caption">
                    <div class="ph-caption-inner">

                        <h2 class="ph-caption-subtitle">
                            <span class="tt-cap-word-wrap">
                                <span class="tt-cap-word">Voir l’invisible.</span>
                            </span>
                            <span class="tt-cap-word-wrap">
                                <span class="tt-cap-word">Maîtriser</span>
                            </span>
                            <span class="tt-cap-word-wrap">
                                <span class="tt-cap-word">le sous-sol.</span>
                            </span>
                        </h2>

                        <h1 class="ph-caption-title">
                            <span class="tt-cap-word-wrap">
                                <span class="tt-cap-word">Contactez-nous</span>
                            </span>
                        </h1>

                    </div>
                </div>
            </div>

            <!-- MASK (kept for animation, cleaned empty spans) -->
            <div
                class="page-header-inner ph-mask"
                style="--y: 46.51539708265802%; --x: 49.11504424778761%;"
            >
                <div class="ph-mask-inner tt-wrap">
                    <div class="ph-caption">
                        <div class="ph-caption-inner">

                            <h2 class="ph-caption-subtitle">
                                <span class="tt-cap-word-wrap">
                                    <span class="tt-cap-word">Voir l’invisible.</span>
                                </span>
                                <span class="tt-cap-word-wrap">
                                    <span class="tt-cap-word">Maîtriser</span>
                                </span>
                                <span class="tt-cap-word-wrap">
                                    <span class="tt-cap-word">le sous-sol.</span>
                                </span>
                            </h2>

                            <h1 class="ph-caption-title">
                                <span class="tt-cap-word-wrap">
                                    <span class="tt-cap-word">Écrivez-nous</span>
                                </span>
                            </h1>

                        </div>
                    </div>
                </div>
            </div>

            <!-- SOCIAL -->
            <div class="ph-social">
                <ul>
                    <li>
                        <div class="magnetic-wrap">
                            <a
                                href="https://www.linkedin.com/company/tellurys/?viewAsMember=true"
                                class="tt-magnetic-item"
                                target="_blank"
                                rel="noopener"
                                aria-label="LinkedIn Tellurys"
                            >
                                <i class="fa-brands fa-linkedin" aria-hidden="true"></i>
                            </a>
                        </div>
                    </li>
                </ul>
            </div>

            <!-- SCROLL -->
            <div class="tt-scroll-down">
                <div class="magnetic-wrap">
                    <a
                        href="#tt-page-content"
                        class="tt-scroll-down-inner tt-magnetic-item"
                        aria-label="Défiler vers le contenu"
                        data-offset="0"
                    >
                        <div class="tt-scrd-icon"></div>
                        <svg viewBox="0 0 500 500">
                            <defs>
                                <path
                                    d="M50,250c0-110.5,89.5-200,200-200s200,89.5,200,200s-89.5,200-200,200S50,360.5,50,250"
                                    id="textcircle"
                                />
                            </defs>
                            <text dy="30">
                                <textPath xlink:href="#textcircle">
                                    Défilez pour explorer - Défilez pour explorer -
                                </textPath>
                            </text>
                        </svg>
                    </a>
                </div>
            </div>

        </div>

        <!-- ================= CONTENT ================= -->
        <div id="tt-page-content">

            <div class="tt-section padding-top-40 padding-bottom-xlg-120">
                <div class="tt-section-inner tt-wrap">

                    <div class="tt-row tt-xl-row-reverse">

                        <!-- CONTACT INFO -->
                        <div class="tt-col-xl-5">

                            <div class="tt-contact-info margin-bottom-80">

                                <div class="tt-contact-info-inner">

                                    <div class="margin-bottom-50 tt-anim-fadeinup">
                                        <p>
                                            Tellurys Bureau d’études en géophysique, géologie et environnement
                                        </p>
                                    </div>

                                    <div class="tt-contact-details margin-bottom-50 tt-anim-fadeinup">
                                        <h6>Détails</h6>
                                        <ul>

                                            <li>
                                                <span class="tt-cd-icon">
                                                    <i class="fas fa-map-marker-alt"></i>
                                                </span>
                                                <a
                                                    href="#"
                                                    class="tt-link"
                                                    target="_blank"
                                                    rel="noopener"
                                                >
                                                    10, Avenue Ibn Rifaâ, 3eme Étage À Droite - Casablanca
                                                </a>
                                            </li>

                                            <li>
                                                <span class="tt-cd-icon">
                                                    <i class="fas fa-phone"></i>
                                                </span>
                                                <a href="tel:+212600089098" class="tt-link">
                                                    +212 600 089 098
                                                </a>
                                            </li>

                                            <li>
                                                <span class="tt-cd-icon">
                                                    <i class="fas fa-envelope"></i>
                                                </span>
                                                <a href="mailto:contact@tellurys.ma" class="tt-link">
                                                    contact@tellurys.ma
                                                </a>
                                            </li>

                                        </ul>
                                    </div>

                                    <div class="tt-social-buttons margin-bottom-50 tt-anim-fadeinup">
                                        <h6>Suivez-nous</h6>
                                        <ul>
                                            <li>
                                                <div class="magnetic-wrap">
                                                    <a
                                                        href="https://www.linkedin.com/company/tellurys/?viewAsMember=true"
                                                        class="tt-magnetic-item"
                                                        target="_blank"
                                                        rel="noopener"
                                                        aria-label="LinkedIn Tellurys"
                                                    >
                                                        <i class="fa-brands fa-linkedin" aria-hidden="true"></i>
                                                    </a>
                                                </div>
                                            </li>
                                        </ul>
                                    </div>

                                </div>
                            </div>

                        </div>

                        <!-- FORM -->
                        <div class="tt-col-xl-7">

                            <form
                                id="tt-contact-form"
                                class="tt-form tt-form-creative tt-form-lg"
                            >

                                <div id="tt-contact-form-messages" role="alert">
                                    <div class="tt-cfm-inner"></div>
                                    <div class="tt-cfm-close hide-cursor">
                                        <i class="fa-solid fa-xmark"></i>
                                    </div>
                                </div>

                                <div class="tt-contact-form-inner">

                                    <div class="tt-form-group tt-anim-fadeinup">
                                        <label>Quel est votre nom ? <span class="required">*</span></label>
                                        <input class="tt-form-control" type="text" name="name" required />
                                    </div>

                                    <div class="tt-form-group tt-anim-fadeinup">
                                        <label>Quel est votre email ? <span class="required">*</span></label>
                                        <input class="tt-form-control" type="email" name="email" required />
                                    </div>

                                    <div class="tt-form-group tt-anim-fadeinup">
                                        <label>Quel service vous intéresse ? <span class="required">*</span></label>
                                        <select class="tt-form-control" name="option" required>
                                            <option value="" disabled selected>Veuillez choisir un service</option>
                                            <option>Géophysique</option>
                                            <option>Géologie</option>
                                            <option>Hydrogéologie</option>
                                            <option>Environnement et risques naturels</option>
                                            <option>Génie civil – Géotechnique</option>
                                            <option>Mines & Carrières</option>
                                            <option>Télédétection & SIG</option>
                                        </select>
                                    </div>

                                    <div class="tt-form-group tt-anim-fadeinup">
                                        <label>Votre message <span class="required">*</span></label>
                                        <textarea class="tt-form-control" name="message" rows="5" required></textarea>
                                    </div>

                                    <div class="tt-anim-fadeinup">
                                        <div class="magnetic-wrap tt-magnetic-btn">
                                            <button type="submit" class="tt-btn tt-btn-primary tt-magnetic-item">
                                                <span class="tt-btn-inner">
                                                    <span data-hover="Envoyer le message">
                                                        Envoyer le message
                                                    </span>
                                                </span>
                                            </button>
                                        </div>
                                    </div>

                                </div>
                            </form>

                        </div>

                    </div>

                </div>
            </div>

            <CTA />

        </div>
    </div>
</Layout>